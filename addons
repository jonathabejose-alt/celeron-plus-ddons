local function getClosestTeammate() 
    local character = player.Character
    local root = character and character:FindFirstChild("HumanoidRootPart") 
    if not root then return nil end 

    local closest = nil 
    local closestDistSq = math.huge 
    local pPos = root.Position
    local pTeam = player.Team
    local playersList = Players:GetPlayers()

    for i = 1, #playersList do 
        local plr = playersList[i]
        if plr ~= player and plr.Team == pTeam and plr.Character then 
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart") 
            if hrp then 
                local tPos = hrp.Position
                local distX = pPos.X - tPos.X
                local distY = pPos.Y - tPos.Y
                local distZ = pPos.Z - tPos.Z
                local distSq = (distX * distX) + (distY * distY) + (distZ * distZ)
                
                if distSq < closestDistSq then 
                    closestDistSq = distSq 
                    closest = plr 
                end 
            end 
        end 
    end 
    return closest 
end 

local function fireSkill(skillName, targetPlayer) 
    local args 
    if autoSkillState.useClosestTeammate and targetPlayer then 
        local targetChar = targetPlayer.Character
        if targetChar then
            args = { buffer.fromstring(buffers["base"]), { { skillName, targetChar } } } 
        else
            args = { buffer.fromstring(buffers["base"]), { { skillName } } } 
        end
    else 
        args = { buffer.fromstring(buffers["base"]), { { skillName } } } 
    end 
    byteNetReliable:FireServer(unpack(args)) 
end 

local toggleKeys = { "toggleCounter1", "toggleCounter2", "toggleCounter3", "toggleCounter4", "toggleCounter5" }

local function onCharacterAdded(char)
    local humanoid = char:WaitForChild("Humanoid", 5)
    if not humanoid then return end
    local animator = humanoid:FindFirstChildOfClass("Animator") or humanoid:WaitForChild("Animator", 3)
    if not animator then return end
    local target = Players:GetPlayerFromCharacter(char)
    if not target or target == player or target.Team == player.Team then return end
    if connections[target] then connections[target]:Disconnect() end
    
    connections[target] = animator.AnimationPlayed:Connect(function(animTrack)
        isTackleAnim = false
        for i = 1, #tackle_anim do
            if animTrack.Animation.AnimationId == tackle_anim[i] then
                isTackleAnim = true
                break
            end
        end
        
        if isTackleAnim then
            local character = player.Character
            local root = character and character:FindFirstChild("HumanoidRootPart")
            local targetHRP = char:FindFirstChild("HumanoidRootPart")
            if root and targetHRP then
                local pPos = root.Position
                local tPos = targetHRP.Position
                local distX = pPos.X - tPos.X
                local distY = pPos.Y - tPos.Y
                local distZ = pPos.Z - tPos.Z
                local distSq = (distX * distX) + (distY * distY) + (distZ * distZ)
                if distSq > maxCheckBoii then return end
            else
                return
            end
            local now = tick()
            if now - (autoSkillState.cooldowns[target] or 0) >= 0.5 then
                autoSkillState.cooldowns[target] = now
                local closestTeammate = autoSkillState.useClosestTeammate and getClosestTeammate() or nil
                for i = 1, 5 do
                    local toggleKey = toggleKeys[i]
                    if autoSkillState[toggleKey] then
                        local skillName = autoSkillState.autoSkills[toggleKey]
                        if skillName then fireSkill(skillName, closestTeammate) end
                    end
                end
                if autoSkillState.toggleTSpecial then
                    task.delay(0.05, function()
                        local tsName = autoSkillState.autoSkills["toggleTSpecial"]
                        if tsName then fireSkill(tsName, closestTeammate) end
                    end)
                end
                if autoSkillState.toggleDetection then
                    local dribbleName = autoSkillState.autoSkills["toggleDetection"]
                    if dribbleName then fireSkill(dribbleName, closestTeammate) end
                end
            end
        end
    end)
end

